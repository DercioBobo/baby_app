# Pass Authorization header to PHP (required on shared hosting / CGI)
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Block direct browser access to config and helpers
<FilesMatch "^(config|helpers)\.php$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Disable directory listing
Options -Indexes
